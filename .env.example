# Claude Vision API (for real food analysis)
# Sign up: https://console.anthropic.com/
VITE_CLAUDE_API_KEY=

# USDA FoodData Central API (for nutrition data)
# Sign up: https://fdc.nal.usda.gov/api-key-signup.html
VITE_USDA_API_KEY=

# Demo mode (set to 'true' to use pre-cached demo meals)
VITE_DEMO_MODE=false

# Supabase Configuration (for persistent data storage & image uploads)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
